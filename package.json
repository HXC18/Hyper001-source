{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "admin": "npm run admin:local",
    "admin:local": "node admin/server.js",
    "admin:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "admin:worker:deploy": "wrangler deploy --config cloudflare/admin-api/wrangler.toml",
    "admin:worker:dev": "wrangler dev --config cloudflare/admin-api/wrangler.toml",
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "publish:manual": "git pull --ff-only origin main && npm run build && npm run deploy",
    "server": "hexo server"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "hexo": "^8.0.0",
    "hexo-abbrlink": "^2.2.1",
    "hexo-deployer-git": "^4.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-fluid": "^1.9.9",
    "hexo-theme-landscape": "^1.0.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.5",
    "slugify": "^1.6.8"
  },
  "devDependencies": {
    "wrangler": "^4.79.0"
  }
}
